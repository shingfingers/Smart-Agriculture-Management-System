<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.itbaizhan.farm_system.mapper.RoleMapper">
    <!-- 根据角色ID查询权限ID列表 -->
    <select id="selectRolePermissionIds" resultType="Long">
        SELECT permission_id FROM sys_role_permission WHERE role_id = #{roleId}
    </select>

    <!-- 根据角色ID删除角色-权限关联 -->
    <delete id="deleteRolePermissionByRoleIds">
        DELETE FROM sys_role_permission WHERE role_id IN
        <foreach collection="roleIds" item="roleId" open="(" separator="," close=")">
            #{roleId}
        </foreach>
    </delete>

    <!-- 批量插入角色与权限关联 -->
    <insert id="insertRolePermissions">
        INSERT INTO sys_role_permission (role_id, permission_id)
        VALUES
        <foreach collection="permissionIds" item="permissionId" separator=",">
            (#{roleId}, #{permissionId})
        </foreach>
    </insert>

    <!-- 根据角色ID删除角色-用户关联 -->
    <delete id="deleteUserRolesByRoleIds">
        DELETE FROM sys_user_role WHERE role_id IN
        <foreach collection="roleIds" item="roleId" open="(" separator="," close=")">
            #{roleId}
        </foreach>
    </delete>

    <!-- 查询拥有该角色的用户id列表 -->
    <select id="selectRoleUserIds" resultType="Long">
        SELECT user_id FROM sys_user_role WHERE role_id = #{roleId}
    </select>

    <!-- 根据角色ID和用户ID列表删除用户角色关联 -->
    <delete id="deleteUserRolesByRoleIdAndUserIds">
        DELETE FROM sys_user_role WHERE role_id = #{roleId} AND user_id IN
        <foreach collection="userIds" item="userId" open="(" separator="," close=")">
            #{userId}
        </foreach>
    </delete>

    <!-- 检查用户角色关联是否存在 -->
    <select id="countUserRoleExists" resultType="int">
        SELECT COUNT(*) FROM sys_user_role WHERE role_id = #{roleId} AND user_id = #{userId}
    </select>

    <!-- 插入用户角色关联 -->
    <insert id="insertUserRole">
        INSERT INTO sys_user_role (user_id, role_id) VALUES (#{userId}, #{roleId})
    </insert>
</mapper>